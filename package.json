{
  "name": "powerdesk",
  "private": true,
  "version": "0.1.0",
  "description": "PowerDesk — A modern file manager for Windows.",
  "author": "Faycal",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently --kill-others \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win dir",
    "electron:build:zip": "vite build && electron-builder --win dir && node scripts/zip-portable.js",
    "electron:build:nsis": "vite build && electron-builder --win nsis",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.powerdesk.app",
    "productName": "PowerDesk",
    "win": {
      "target": "dir",
      "icon": "assets/icon.ico"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "!**/node_modules/**/{test,__tests__,tests,powered-test,example,examples}"
    ],
    "extraResources": [
      { "from": "bin/pdx-index.exe", "to": "bin/pdx-index.exe" }
    ],
    "asar": true
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "lucide-react": "^0.468.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.35.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "wait-on": "^8.0.3"
  }
}
